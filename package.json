{
  "name": "markdown-reader",
  "productName": "Markdown Reader",
  "version": "0.1.0",
  "description": "A macOS-focused Electron markdown file viewer with themes and browser-style zoom.",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "electron .",
    "build": "vite build",
    "icons": "node scripts/make-icons.mjs",
    "dist:mac": "npm run icons && npm run build && electron-builder --mac dir"
  },
  "dependencies": {
    "dompurify": "^3.2.3",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.markdownreader.app",
    "productName": "Markdown Reader",
    "executableName": "Markdown Reader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd"
        ],
        "name": "Markdown Document",
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "extendInfo": {
        "CFBundleName": "Markdown Reader",
        "CFBundleDisplayName": "Markdown Reader",
        "CFBundleExecutable": "Markdown Reader",
        "CFBundleIdentifier": "com.markdownreader.app"
      },
      "target": [
        "dir"
      ]
    }
  }
}
